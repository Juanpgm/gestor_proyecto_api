#Configuración de Base de datos en PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dev
DB_USER=postgres  
DB_PASSWORD=root
DB_SCHEMA=public

# Configuración de PostGIS
POSTGIS_VERSION=3.3

# Configuración del logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Configuración de la aplicación
APP_NAME=API Gestor de Proyectos
APP_VERSION=1.0.0
APP_ENV=development

# Configuración de Conexión
CONNECTION_TIMEOUT=30
POOL_SIZE=5 
MAX_OVERFLOW=10